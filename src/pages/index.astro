---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
	<Header />
	
	<main class="flex-grow pt-16">
		<!-- Hero Section -->
		<section class="relative overflow-hidden bg-slate-900 pt-24 pb-32 sm:pt-32 sm:pb-40">
			<!-- Abstract Background -->
			<div class="absolute inset-0 z-0">
				<div class="absolute inset-0 bg-[linear-gradient(to_right,#4f4f4f2e_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f2e_1px,transparent_1px)] bg-[size:14px_24px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]"></div>
				<div class="absolute right-0 top-0 -mr-20 -mt-20 w-96 h-96 rounded-full bg-cyan-500/20 blur-3xl opacity-50 mix-blend-screen"></div>
				<div class="absolute left-0 bottom-0 -ml-20 -mb-20 w-80 h-80 rounded-full bg-blue-600/20 blur-3xl opacity-50 mix-blend-screen"></div>
			</div>

			<div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center pt-10">
				<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-cyan-500/10 border border-cyan-500/20 text-cyan-400 text-sm font-medium mb-8">
					<span class="flex w-2 h-2 rounded-full bg-cyan-500 animate-pulse"></span>
					Securing the Future of AI
				</div>
				<h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-white mb-8">
					Next-Gen <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">AI Security</span>
					<br /> Consulting & Training
				</h1>
				<p class="mt-4 max-w-2xl mx-auto text-xl text-slate-400 mb-10">
					Empowering organizations to build resilient AI systems through expert consulting and elite online courses. Defend against tomorrow's threats, today.
				</p>
				<div class="flex flex-col sm:flex-row justify-center gap-4">
					<a href="#consulting" class="inline-flex justify-center items-center py-3 px-8 text-base font-semibold rounded-lg bg-cyan-500 text-white hover:bg-cyan-400 focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:ring-offset-2 focus:ring-offset-slate-900 transition-all shadow-lg shadow-cyan-500/30">
						Get a Security Audit
					</a>
					<a href="#courses" class="inline-flex justify-center items-center py-3 px-8 text-base font-semibold border border-slate-700 rounded-lg bg-slate-800 text-white hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-offset-2 focus:ring-offset-slate-900 transition-all">
						Browse Courses
					</a>
				</div>
			</div>
		</section>

		<!-- Services / Consulting Section -->
		<section id="consulting" class="py-24 bg-slate-950 relative">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="text-center mb-16">
					<h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Enterprise AI Security Consulting</h2>
					<p class="text-slate-400 max-w-2xl mx-auto">We identify vulnerabilities in your LLMs and AI infrastructure before malicious actors do.</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<!-- Service 1 -->
					<div class="p-8 rounded-2xl bg-slate-900 border border-slate-800 hover:border-cyan-500/50 transition-colors group">
						<div class="w-12 h-12 rounded-lg bg-cyan-500/10 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
							<svg class="w-6 h-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
						</div>
						<h3 class="text-xl font-bold text-white mb-3">Threat Modeling</h3>
						<p class="text-slate-400">Comprehensive analysis of your AI architecture to identify potential attack vectors and systemic risks.</p>
					</div>
					<!-- Service 2 -->
					<div class="p-8 rounded-2xl bg-slate-900 border border-slate-800 hover:border-cyan-500/50 transition-colors group">
						<div class="w-12 h-12 rounded-lg bg-blue-500/10 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
							<svg class="w-6 h-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>
						</div>
						<h3 class="text-xl font-bold text-white mb-3">Red Teaming</h3>
						<p class="text-slate-400">Simulated attacks on your LLMs (prompt injection, jailbreaks) to evaluate robust defenses.</p>
					</div>
					<!-- Service 3 -->
					<div class="p-8 rounded-2xl bg-slate-900 border border-slate-800 hover:border-cyan-500/50 transition-colors group">
						<div class="w-12 h-12 rounded-lg bg-emerald-500/10 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
							<svg class="w-6 h-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
						</div>
						<h3 class="text-xl font-bold text-white mb-3">Compliance Audits</h3>
						<p class="text-slate-400">Ensure your AI systems comply with emerging regulations like the EU AI Act and standard security frameworks minimize legal exposure.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Courses Section -->
		<section id="courses" class="py-24 bg-slate-900 relative border-y border-white/5">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
					<div class="max-w-2xl">
						<h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Elite Online Courses</h2>
						<p class="text-slate-400">Master the art of AI defense with our rigorous, hands-on training programs designed by industry veterans.</p>
					</div>
					<a href="#" class="inline-flex items-center text-cyan-400 font-semibold hover:text-cyan-300 transition-colors">
						View All Courses <svg class="ml-2 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
					</a>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
					<!-- Course 1 -->
					<div class="rounded-2xl bg-slate-800/50 border border-slate-700/50 overflow-hidden group hover:border-cyan-500/30 transition-all hover:shadow-lg hover:shadow-cyan-500/10">
						<div class="h-48 bg-slate-800 relative overflow-hidden flex items-center justify-center">
							<div class="absolute inset-0 bg-gradient-to-br from-blue-900/40 to-slate-900"></div>
							<svg class="w-16 h-16 text-slate-600 group-hover:text-cyan-500/50 transition-colors relative z-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
						</div>
						<div class="p-6">
							<div class="text-xs font-bold tracking-widest text-cyan-400 uppercase mb-2">Beginner</div>
							<h3 class="text-lg font-bold text-white mb-2">Foundations of AI Security</h3>
							<p class="text-slate-400 text-sm mb-4">An introduction to vulnerabilities in machine learning models and fundamental defense strategies.</p>
							<div class="flex items-center justify-between mt-6">
								<span class="text-white font-bold">$299</span>
								<button class="px-4 py-2 rounded-lg bg-slate-700 text-white text-sm font-medium hover:bg-slate-600 transition-colors">Enroll Now</button>
							</div>
						</div>
					</div>
					<!-- Course 2 -->
					<div class="rounded-2xl bg-slate-800/50 border border-slate-700/50 overflow-hidden group hover:border-cyan-500/30 transition-all hover:shadow-lg hover:shadow-cyan-500/10">
						<div class="h-48 bg-slate-800 relative overflow-hidden flex items-center justify-center">
							<div class="absolute inset-0 bg-gradient-to-br from-cyan-900/40 to-slate-900"></div>
							<svg class="w-16 h-16 text-slate-600 group-hover:text-cyan-500/50 transition-colors relative z-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
						</div>
						<div class="p-6">
							<div class="text-xs font-bold tracking-widest text-blue-400 uppercase mb-2">Advanced</div>
							<h3 class="text-lg font-bold text-white mb-2">LLM Red Teaming Masterclass</h3>
							<p class="text-slate-400 text-sm mb-4">Deep dive into prompt injections, jailbreaks, and advanced exploitation techniques for large language models.</p>
							<div class="flex items-center justify-between mt-6">
								<span class="text-white font-bold">$599</span>
								<button class="px-4 py-2 rounded-lg bg-cyan-600 text-white text-sm font-medium hover:bg-cyan-500 transition-colors">Enroll Now</button>
							</div>
						</div>
					</div>
					<!-- Course 3 -->
					<div class="rounded-2xl bg-slate-800/50 border border-slate-700/50 overflow-hidden group hover:border-cyan-500/30 transition-all hover:shadow-lg hover:shadow-cyan-500/10">
						<div class="h-48 bg-slate-800 relative overflow-hidden flex items-center justify-center">
							<div class="absolute inset-0 bg-gradient-to-br from-emerald-900/40 to-slate-900"></div>
							<svg class="w-16 h-16 text-slate-600 group-hover:text-cyan-500/50 transition-colors relative z-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
						</div>
						<div class="p-6">
							<div class="text-xs font-bold tracking-widest text-emerald-400 uppercase mb-2">Professional</div>
							<h3 class="text-lg font-bold text-white mb-2">Securing MLOps Pipelines</h3>
							<p class="text-slate-400 text-sm mb-4">Learn how to implement zero-trust architectures and secure your machine learning deployment pipelines.</p>
							<div class="flex items-center justify-between mt-6">
								<span class="text-white font-bold">$449</span>
								<button class="px-4 py-2 rounded-lg bg-slate-700 text-white text-sm font-medium hover:bg-slate-600 transition-colors">Enroll Now</button>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Contact Section -->
		<section id="contact" class="py-24 bg-slate-950">
			<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="bg-slate-900 border border-slate-800 rounded-3xl p-8 md:p-12 relative overflow-hidden">
					<div class="absolute top-0 right-0 -mr-20 -mt-20 w-64 h-64 rounded-full bg-cyan-500/10 blur-3xl mix-blend-screen pointer-events-none"></div>
					
					<div class="text-center mb-10 relative z-10">
						<h2 class="text-3xl font-bold text-white mb-4">Ready to secure your AI?</h2>
						<p class="text-slate-400">Get in touch with our security experts to discuss your consulting needs or corporate training solutions.</p>
					</div>

					<form class="space-y-6 relative z-10" onsubmit="event.preventDefault();">
						<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
							<div>
								<label for="name" class="block text-sm font-medium text-slate-300 mb-2">Full Name</label>
								<input type="text" id="name" class="w-full bg-slate-950 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:border-transparent transition-shadow" placeholder="John Doe">
							</div>
							<div>
								<label for="email" class="block text-sm font-medium text-slate-300 mb-2">Email Address</label>
								<input type="email" id="email" class="w-full bg-slate-950 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:border-transparent transition-shadow" placeholder="john@example.com">
							</div>
						</div>
						<div>
							<label for="interest" class="block text-sm font-medium text-slate-300 mb-2">Primary Interest</label>
							<select id="interest" class="w-full bg-slate-950 border border-slate-700 rounded-lg px-4 py-3 text-white justify-between appearance-none focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:border-transparent transition-shadow">
								<option>AI Security Consulting</option>
								<option>Corporate Team Training</option>
								<option>Individual Courses</option>
								<option>Other</option>
							</select>
						</div>
						<div>
							<label for="message" class="block text-sm font-medium text-slate-300 mb-2">Message</label>
							<textarea id="message" rows="4" class="w-full bg-slate-950 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:border-transparent transition-shadow" placeholder="How can we help you?"></textarea>
						</div>
						<button type="submit" class="w-full py-4 px-8 bg-cyan-500 text-white font-bold rounded-lg hover:bg-cyan-400 focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:ring-offset-2 focus:ring-offset-slate-900 transition-all shadow-lg shadow-cyan-500/20">
							Send Message
						</button>
					</form>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
